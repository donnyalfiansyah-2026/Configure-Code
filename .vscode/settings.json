{
  "workbench.colorTheme": "Default Dark+",
  "workbench.iconTheme": "vs-seti",
  "workbench.startupEditor": "none",
  "workbench.editor.labelFormat": "short",
  "workbench.tree.enableStickyScroll": true,
  "workbench.list.smoothScrolling": true,
  "workbench.editor.enablePreview": false,
  "workbench.editor.limit.enabled": true,
  "workbench.editor.limit.value": 12,
  "workbench.editor.limit.perEditorGroup": true,

  "workbench.colorCustomizations": {
    "terminal.background": "#0b1220",
    "terminal.foreground": "#e2e8f0",
    "terminalCursor.foreground": "#e2e8f0",
    "terminal.selectionBackground": "#1e293b",
    "terminal.ansiBlack": "#0f172a",
    "terminal.ansiRed": "#ef4444",
    "terminal.ansiGreen": "#22c55e",
    "terminal.ansiYellow": "#f59e0b",
    "terminal.ansiBlue": "#3b82f6",
    "terminal.ansiMagenta": "#a855f7",
    "terminal.ansiCyan": "#06b6d4",
    "terminal.ansiWhite": "#e2e8f0",
    "terminal.ansiBrightBlack": "#334155",
    "terminal.ansiBrightRed": "#f87171",
    "terminal.ansiBrightGreen": "#4ade80",
    "terminal.ansiBrightYellow": "#fbbf24",
    "terminal.ansiBrightBlue": "#60a5fa",
    "terminal.ansiBrightMagenta": "#c084fc",
    "terminal.ansiBrightCyan": "#22d3ee",
    "terminal.ansiBrightWhite": "#f8fafc"
  },

  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.fixAll.eslint": "explicit"
  },
  "editor.fontFamily": "Fira Code, Monaspace Neon, Monaspace Argon, Cascadia Code, Consolas, 'Courier New', monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.fontWeight": "400",
  "editor.lineHeight": 22,
  "editor.letterSpacing": 0.3,
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,
  "editor.rulers": [100],
  "editor.minimap.enabled": false,
  "editor.guides.bracketPairs": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.inlineSuggest.enabled": true,
  "editor.suggestSelection": "first",
  "editor.smoothScrolling": true,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.renderWhitespace": "boundary",

  "files.autoSave": "onFocusChange",
  "files.eol": "\n",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.exclude": {
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/dist": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/package-lock.json": true
  },

  "explorer.confirmDelete": true,
  "explorer.confirmDragAndDrop": true,
  "explorer.compactFolders": false,

  "eslint.useFlatConfig": true,
  "eslint.validate": ["javascript", "javascriptreact", "html"],
  "eslint.format.enable": false,

  "css.validate": true,
  "html.validate.scripts": true,
  "html.validate.styles": true,

  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.showPushSuccessNotification": true,
  "scm.diffDecorationsGutterPattern": {
    "added": true,
    "modified": true
  },

  "docker.commands.composeUp": "docker compose up",
  "docker.commands.composeDown": "docker compose down",

  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "terminal.integrated.fontFamily": "Monaspace Neon, Monaspace Argon, Fira Code, Cascadia Code, Consolas, 'Courier New', monospace",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.fontWeight": "400",
  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.tabs.enabled": true,
  "terminal.integrated.defaultLocation": "editor",
  "containers.commands.composeUp": "docker compose up",
  "containers.commands.composeDown": "docker compose down"
}
